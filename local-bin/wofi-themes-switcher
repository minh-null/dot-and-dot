#!/usr/bin/env bash

amethyst_void() {
  rm ~/.local/marchyso-theme/backup/*
  rm  ~/.config/waybar/*
  rm  ~/.config/swaync/*
  cp -r ~/.local/marchyso-theme/amethyst-void/waybar/* ~/.config/waybar
  cp -r ~/.local/marchyso-theme/amethyst-void/swaync/* ~/.config/swaync
  awww img ~/Pictures/Wallpapers/purple.jpg --transition-fps 60 --transition-step 255 --transition-type any
  sleep 1
  waybar-start
  pkill swaync
  swaync &
}

