# Ordered entries: "Label|function"
menu_entries=(
  "Amethys Void|amethyst_void"
  "Cherrywave|Cherrywave"
  "Catppuchin|Catppuchin"
  "Dock|Dock"
  "Gruvbox Dark"
  "Expressive|sidebar"
)

# Extract labels for display
labels=$(printf "%s\n" "${menu_entries[@]}" | cut -d'|' -f1)

choice=$(printf "%s\n" "$labels" | \
  wofi --dmenu \
     --prompt "Choose your theme" \
     --width 300 \
     --height 500)

# Execute matching function
for entry in "${menu_entries[@]}"; do
  label="${entry%%|*}"
  action="${entry##*|}"
  [[ "$choice" == "$label" ]] && "$action"
done
