#!/usr/bin/env bash

applications() {
  #wofi --show drun --allow-images --columns 2 --show-icons --prompt "Search something . . ."
  wofi --show drun --allow-images --columns 2 --show-icons --prompt "Search something . . ." --width 850
}

calc(){
  rofi -show calc -modi calc -no-show-match -no-sort
}

emoji() {
  rofimoji --selector wofi --clipboard wl-copy --action copy
}

styling() {
  wofi-styling
}

help_menu() {
  wofi-keybinds
}

# Ordered entries: "Label|function"
menu_entries=(
  "         Applications|applications"
  "      󱖦    Calculator|calc"
  "            Emoji|emoji"
  "           Styling|styling"
  "            Help|help_menu"
  "      ⏻      Power|wofi-power-center"
)

# Extract labels for display
labels=$(printf "%s\n" "${menu_entries[@]}" | cut -d'|' -f1)

choice=$(printf "%s\n" "$labels" | \
  wofi --dmenu \
     --prompt "Menu, search something" \
     --width 300 \
     --hide-scroll
     --height 200)

# Execute matching function
for entry in "${menu_entries[@]}"; do
  label="${entry%%|*}"
  action="${entry##*|}"
  [[ "$choice" == "$label" ]] && "$action"
done
